# AEGIS Women Safety Platform — Frontend Environment Variables
# Copy this file to .env.local for local development

# Base URL of the Spring Boot Backend API
VITE_API_BASE_URL=http://127.0.0.1:8080

# WebSocket Endpoint URL of the Spring Boot Backend (for live alerts)
VITE_WS_URL=ws://127.0.0.1:8080/ws

# Base URL of the FastAPI AI Microservice (face analytics, behavioral, etc.)
VITE_AI_API_BASE_URL=http://127.0.0.1:8000

# Google Maps API Key for Maps display (fallback to 'demo' if unavailable)
VITE_GOOGLE_MAPS_API_KEY=demo
